<div class="container">
  <div class="row">
    <div class="mx-auto col-xl-60 col-lg-6 col-md-6 col-sm-8">
      <h1 class="mt-3">welocome to 
          <i class="fa-solid fa-book"></i>
          <strong>Bookers !!</strong>
      </h1>

      <p class="fs-5 mt-3">In 
         <i class="fa-solid fa-book"></i> 
         <strong>Bookers,</strong>
      </p>
      <p class="fs-5 mt-3">you can share and exchange your opinions , inpressions , and emotions</p>
      <p class="fs-5 mt-3">about various books!</p>
    </div>    
  </div>
  <div class="row width-40 mx-auto mt-2">
      <% if authenticated? %>
        <%= link_to "Log in" ,user_path(Current.user), class:"btn btn-primary"%>
        <%= link_to "Sign up",user_path(Current.user),class:"btn btn-success mt-4" %>
      <%else%>
        
        <%= button_to "ゲストログイン（閲覧用）", guest_sign_in_path, class: "btn btn-secondary btn-sm btn-block mb-3 sign_in" %>
        <%= link_to "Log in" ,new_session_path, class:"btn btn-primary"%>
        <%= link_to "Sign up",new_user_path,class:"btn btn-success mt-4" %>
      <%end%>
  </div>
</div>