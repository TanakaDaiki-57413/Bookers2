<div class="container">

  <div class="row justify-content-center">

    <div class="col-md-4">

      <h1 class="mt-3 mb-4">User info</h1>

      <%= form_with model: @user  do |f| %>

        <div class="mb-3">
          <%= f.label :name ,class:"mb-2"%>
          <%= f.text_field :name, class: "form-control" %>
        </div>

        <div class="mb-3">
          <label class="mb-1">Image</label><br>
          <%= f.file_field :profile_image,  accept: "image/*" %> 
        </div>

        <div class="mb-3">
          <%= f.label :introduction ,class:"mb-2"%>
          <%= f.text_area :introduction, class: "form-control" %>
        </div>

        <%= f.submit "Update User", class: "btn btn-secondary" %>

      <% end %>
    </div>
  </div>
</div>