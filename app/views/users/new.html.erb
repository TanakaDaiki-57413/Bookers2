<div class="col-md-9 mx-auto">
  <h1 class="mt-3">Sign up</h1>
  <% if @user.errors.any? %>
    <h1><%= @user.errors.count %> errors prohibited this obj from being saved:</h1>
    <ul class="ms-3">
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <%end%>
    </ul>
  <% end %>


  <%= form_with model: @user, url: users_path do |f| %>
  
    <%= f.label :name ,class:"fs-5 mb-1" %><br>
    <%= f.text_field :name, autofocus: true ,class:"input-op1 px-1 py-1"%><br> 
    <%= f.label :Email ,class:"fs-5 mb-1"%><br>
    <%= f.email_field :email_address ,class:"input-op1 px-1 py-1"%><br>
    <%= f.label :password ,class:"fs-5 mb-1"%>
    <span class="fs-6">(6 characters minimum)</span><br>
    <%= f.password_field :password ,class:"input-op1 px-1 py-1"%><br>
    <%= f.label :password_confirmation ,class:"fs-5 mb-1"%><br>
    <%= f.password_field :password_confirmation ,class:"input-op1 px-1 py-1"%>
    <div class="mt-2">
      <%= f.submit "Sign up" ,class:"btn btn-success fs-7"%>
    </div>
  <%end%>

  <%= link_to "Log in",users_sign_in_path,class:"text-decoration-none fs-6"%>
</div>