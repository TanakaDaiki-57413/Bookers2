<main>
  <div class="container px-5">
    <div class="row">
      <%= render "shared/tmp",new_book: @new_book,user: @user%>
      <%# <画面右側> %>
      <div class="col-md-8 offset-md-1 mt-3">
        <h2>Users</h2>
        <table class="table">
          <thead>
            <tr>
              <th class="col-md-3">image</th>
              <th class="col-md-3">name</th>
              <th class="col-md-5"></th>
              <th class="col-md-1 border-none"></th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td>
                  <%= image_tag user.get_profile_image(80, 80) %>
    
                </td>
                <td><%= user.name %></td>
                <td class="text-center"><%= link_to "Show",user_path(user)%></td>
              </tr>
            <%end%>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>