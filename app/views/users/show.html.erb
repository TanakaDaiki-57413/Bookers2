<main>
  <div class="container px-5">
    <div class="row">
      <%= render "shared/tmp",new_book: @new_book,user: @user%>
      <%# <画面右側> %>
      <div class="col-md-8 offset-md-1 mt-3">
        <h2>Books</h2>
        <table class="table table-hover table-inverse">
          <thead>
            <tr>
              <th class="col-md-2"></th>
              <th class="col-md-3">Title</th>
              <th class="col-md-3">Opinion</th>
              <th class="col-md-3"></th>
            </tr>
          </thead>
          <tbody>
            
            <% @books.each do |book| %>
              <tr>
                <td class="col-2">
                  <%= link_to user_path(book.user) do %>
                    <%= image_tag book.user.get_profile_image(80, 80) %>
                  <% end %>
                </td>
                <td class="col-3"><%=link_to book.title,book_path(book.id)%></td>
                <td class="col-3"><%=book.body%></td>
                <td class="col-3">
                  <p>コメント数：<%= book.book_comments.count %></p>
                </td>
              </tr>
            <%end%>
            <tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>