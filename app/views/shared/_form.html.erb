<% if authenticated?%>
  <%=form_with url:search_path, method: :get do |f| %>
    <%= f.text_field :keyword %>
    <%=f.select :object,[["User","Users"],["Book","Books"]]%>
    <%=f.select :match,[["完全一致","perfect"],["前方一致","start"],["後方一致","end"],["部分一致","cont"]]%>
  
    <%= f.submit "検索"%>
  <%end%>
<%end%>