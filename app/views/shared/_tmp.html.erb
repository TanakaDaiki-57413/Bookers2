<%# 画面左側 %>
<div class="col-md-3 mt-3">
  <%# ユーザーインフォ %>
  <div class="row ">
    <h2>User info</h2>
    <div class="img">
      <%= image_tag @user.get_profile_image(100,100)%>
    </div>
    <div class="row">
      <div class="col">
        <p>name</p>
        <p>introduction</p>
      </div>
      <div class="col">
        <p><%= @user.name%></p>
        <p><%= @user.introduction%></p>
      </div>
    </div>

    <div class="row">
      <div class="col">
        <p>follows</p>
        <p>followers</p>
      </div>
      <div class="col">
        <%= link_to follow_list_path(@user.id) do%>
          <p><%= @user.followings.count%></p>
        <%end%>
        <%= link_to follower_list_path(@user.id) do%>
          <p><%= @user.followers.count%></p>
        <%end%>

      </div>
    </div>
  </div>
  <div class="row">
    <% if Current.user == @user%>
      <% unless @user.guest_user? %>
        <%= link_to edit_user_path(@user.id),class:"btn btn-outline-secondary" do %>
          <i class="fas fa-user-cog"></i>
        <% end %>
      <%end%>

    <%else%>

      <% if Current.user.following?(@user) %>
        <%= link_to "フォローを外す",user_relationships_path(@user.id), data:{turbo_method: :delete},class:"btn btn-primary w-50"%>
        
      <% else %>
        <%= link_to "フォローする",user_relationships_path(@user.id), data:{turbo_method: :post},class:"btn btn-success w-50"%>
        
      <% end %>

    <%end%>

    <% if Current.user != user && Current.user.following?(user) && user.following?(Current.user) %>
      <%= link_to 'chatを始める', chat_path(user.id), class: "ml-3" %>
    <% end %>
  </div>
  <%# NewBook %>
  <div class="row mt-3">
    <h2>New book</h2>
    <%= form_with model:@new_book ,url:books_path  do |f|%>
      <%=f.label :Title %><br>
      <%=f.text_field :title ,class:"form-control"%><br>
      <%=f.label :Opinion %><br>
      <%=f.text_area :body ,class:"form-control "%><br>
      <%=f.submit "Create Book",class:"btn btn-success fs-7"%>
    <%end%>
  </div>
</div>