<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<div class="width-85 mx-auto">
  <h1 class="mt-3">Log in</h1>

  <%= form_with url: session_path do |form| %>
    <%= form.label :name ,class:"fs-5 mb-1" %><br>
    <%= form.text_field :name, required: true, autofocus: true, autocomplete: "username", value: params[:name] ,class:"input-op1 px-1 py-1"%><br>
    <%= form.label :password ,class:"fs-5 mb-1" %><br>
    <%= form.password_field :password, required: true, autocomplete: "current-password",  maxlength: 72 ,class:"input-op1 px-1 py-1" %><br>
    <div class="mt-2">
      <%= form.submit "Log in" ,class:"btn btn-primary fs-7"%>
    </div>
  <% end %>

  <%= link_to "Sign up",new_user_path,class:"text-decoration-none fs-6"%>
  <br>
  <%= link_to "Forgot password?", new_password_path ,class:"text-decoration-none fs-6"%>
</div>