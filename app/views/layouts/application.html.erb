<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Bookers2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Bookers2">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- FontAwesomeの読み込み -->
    <script src="https://kit.fontawesome.com/a9c9cb6030.js" crossorigin="anonymous"></script>
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">


    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :application, "data-turbo-track": "reload" %>
    
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <nav class="navbar navbar-expand-lg navbar-light bg-dark h-50 p-3">
        <div class="container">
          <%= link_to "Bookers",root_path,class:"link-light link-offset-2 link-underline link-underline-opacity-0 fs-4 ms-5" %>
          <button
            class="navbar-toggler collapsed bg-light text-white"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNav"
            aria-controls="navbarToggleExternalContent"
            aria-expanded="false"
            aria-label="Toggle navigation"
          >
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto fs-6 me-4">
              
              <% if authenticated? %>
                <li class="nav-item me-4">
                  <%= link_to user_path(Current.user.id),class:"text-decoration-none link-light " do%>
                   <i class="fa-solid fa-house"></i>
                   <span>Home</span>
                  <%end%>
                </li>
                <li class="nav-item me-4">
                  <%= link_to users_path,class:"text-decoration-none link-light" do%>
                    <i class="fa-solid fa-users"></i>
                    <span>Users</span>
                  <%end%>
                </li>
                <li class="nav-item me-4">
                  <%= link_to books_path,class:" text-decoration-none link-light " do%>
                    <i class="fa-solid fa-book-open"></i>
                    <span>Books</span>
                  <%end%>
                </li>
                <li class="nav-item me-4">
                  <%= link_to session_path ,data: { turbo_method: :delete, turbo_confirm: "ログアウトしますか？" },class:"text-decoration-none link-light" do%>
                    <i class="fa-solid fa-right-to-bracket"></i>
                    <span>Log out</span>
                  <%end%> 
                </li>                
              <%else%>
                <li class="nav-item me-4">
                  <%= link_to root_path,class:"text-decoration-none link-light " do%>
                   <i class="fa-solid fa-house"></i>
                   <span>Home</span>
                  <%end%>
                </li>
                <li class="nav-item me-4">
                  <%= link_to about_path,class:"text-decoration-none link-light" do%>
                    <i class="fa-solid fa-link"></i>
                    <span>About</span>
                  <%end%>
                </li>
                <li class="nav-item me-4">
                  <%= link_to new_user_path,class:" text-decoration-none link-light " do%>
                    <i class="fa-solid fa-user-plus"></i>
                    <span>Sign up</span>
                  <%end%>
                </li>
                <li class="nav-item me-4">
                  <%= link_to users_sign_in_path,class:"text-decoration-none link-light" do%>
                    <i class="fa-solid fa-right-to-bracket"></i>
                    <span>Log in</span>
                  <%end%> 
                </li>
              <%end%>
          </div>

        </div>
      </nav>
    </header>

    <% flash.each do |message_type, message| %>
      <%= message %>
    <% end %>
    <%= yield %>

    <footer>
      <div class="container mt-5">
        <div class="row text-center">
          <p class="mx-auto fs-5">CopyRight Infratop.inc</p>
        </div>
      </div>
    </footer>

    <!-- Bootstrap 5.3 JS -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
  </body>
</html>
