<main>
  <div class="container px-5">
    <div class="row">
      <% if @new_book.errors.any? %>

        <h1><%= @new_book.errors.count %> errors prohibited this obj from being saved:</h1>

        <ul class="ms-5">
          <% @new_book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
          <%end%>
        </ul>
      <% end %>
      <%= render "shared/tmp",new_book: @new_book,user: @user%>
      <%# <画面右側> %>
      <div class="col-md-8 offset-md-1 mt-3">
        <h2>Books</h2>
        <table class="table table-hover table-inverse">
          <thead>
            <tr>
              <th class="col-md-2"></th>
              <th class="col-md-2">Title</th>
              <th class="col-md-2">Opinion</th>
              <th class="col-md-1"></th>
              <th></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            
            <% @books.each do |book| %>
              <tr>
                <td>
                  <%= link_to user_path(book.user) do %>
                    <%= image_tag book.user.get_profile_image(50, 50) %>
                  <% end %>
                </td>
                <td><%=link_to book.title,book_path(book.id)%></td>
                <td><%=book.body%></td>
                
                <td>
                  <%= render "favorites/favorite_btn" ,book:book%>
                </td>
                <td>
                  <p>コメント数：<%= book.book_comments.count %></p>
                </td>
                <td>
                  <p>閲覧数：<%= book.view_counts.pick(:view_count) %></p>
                </td>
              </tr>
            <%end%>
            <tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>