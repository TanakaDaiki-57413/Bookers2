<main>
  <div class="container px-5">
    <div class="row">
      <% if @book.errors.any? %>

        <h1><%= @book.errors.count %> errors prohibited this obj from being saved:</h1>

        <ul class="ms-5">
          <% @book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
          <%end%>
        </ul>
      <% end %>
      <%= render "shared/tmp",new_book: @new_book,user: @user%>
      <%# <画面右側> %>
      <div class="col-md-8 offset-md-1 mt-3">
        <h2>Books</h2>
        <table class="table table-hover table-inverse">
          <thead>
            <tr>
              <th class="col-md-2"></th>
              <th class="col-md-3">Title</th>
              <th class="col-md-2">Opinion</th>
              <th class="col-md-2"></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            
            <% @books.each do |book| %>
              <tr>
                <td>
                  <%= link_to user_path(book.user) do %>
                    <%= image_tag book.user.get_profile_image(50, 50) %>
                  <% end %>
                </td>
                <td><%=link_to book.title,book_path(book.id)%></td>
                <td><%=book.body%></td>
                
                <% if book.favorited_by?(Current.user)%>
                  <td>
                    <%= link_to book_favorite_path(book,source:"index"),data: {turbo_method: :delete},class:"text-decoration-none" do %>
                      <span class="text-danger">♥</span>
                      <%= book.favorites.count%>
                    <%end%>
                  </td>
                  
                <%else%>
                  <td>
                    <%= link_to book_favorite_path(book,source:"index"),data: {turbo_method: "post"},class:"text-decoration-none" do%>
                      <span class="text-primary">♥</span>
                      <%= book.favorites.count %>
                    <%end%>
                  </td>
                <%end%>

                <td>
                  <p>コメント数：<%= book.book_comments.count %></p>
                </td>
              </tr>
            <%end%>
            <tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>